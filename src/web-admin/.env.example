# ─────────────────────────────────────────────────────────────────────────────
# PayOS credentials
# Get from: https://my.payos.vn → Quản lý ứng dụng API → Tạo ứng dụng
# (Sandbox): https://my-dev.payos.vn
# ─────────────────────────────────────────────────────────────────────────────
PAYOS_CLIENT_ID=your_client_id_here
PAYOS_API_KEY=your_api_key_here
PAYOS_CHECKSUM_KEY=your_checksum_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Your deployed web URL (no trailing slash) — used for returnUrl / cancelUrl
# Local dev: http://localhost:5174
# Production: https://your-app.vercel.app
# ─────────────────────────────────────────────────────────────────────────────
VITE_WEB_URL=http://localhost:5174

# ─────────────────────────────────────────────────────────────────────────────
# Firebase Admin SDK service account (for Vercel serverless functions)
# Steps:
#   1. Firebase Console → Project Settings → Service Accounts
#   2. Click "Generate new private key" → download JSON
#   3. Minify the JSON (remove whitespace) and paste it here as a single line
# ─────────────────────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}

# ─────────────────────────────────────────────────────────────────────────────
# Pro price in VND (default: 299000)
# ─────────────────────────────────────────────────────────────────────────────
PRO_PRICE_VND=299000
