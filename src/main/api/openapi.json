{
  "openapi": "3.0.0",
  "info": {
    "title": "HL-MCK Automation Antidetect Browser API",
    "version": "1.0.0",
    "description": "REST API for browser profile management and automation. Access Swagger UI at /docs."
  },
  "components": {
    "schemas": {}
  },
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Server health check",
        "tags": ["health"],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/profiles/": {
      "get": {
        "summary": "List all profiles",
        "tags": ["profiles"],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      },
      "post": {
        "summary": "Create a new profile",
        "tags": ["profiles"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 100
                  },
                  "headless": {
                    "type": "boolean"
                  },
                  "fingerprintOptions": {
                    "type": "object",
                    "properties": {
                      "os": {
                        "type": "string",
                        "enum": ["windows", "macos", "linux"]
                      },
                      "browser": {
                        "type": "string",
                        "enum": ["chrome", "firefox", "edge"]
                      },
                      "device": {
                        "type": "string",
                        "enum": ["desktop", "mobile"]
                      },
                      "locale": {
                        "type": "string"
                      }
                    }
                  },
                  "proxy": {
                    "type": "object",
                    "required": ["type", "host", "port"],
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": ["http", "https", "socks4", "socks5"]
                      },
                      "host": {
                        "type": "string"
                      },
                      "port": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 65535
                      },
                      "username": {
                        "type": "string"
                      },
                      "password": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/profiles/{id}": {
      "put": {
        "summary": "Update a profile",
        "tags": ["profiles"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 100
                  },
                  "headless": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      },
      "delete": {
        "summary": "Delete a profile",
        "tags": ["profiles"],
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/browsers/{profileId}/launch": {
      "post": {
        "summary": "Launch browser for a profile",
        "tags": ["browsers"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "headless": {
                    "type": "boolean",
                    "description": "Run in headless mode"
                  }
                }
              }
