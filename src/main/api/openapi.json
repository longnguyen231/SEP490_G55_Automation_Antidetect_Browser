    "/api/tasks/": {
      "get": {
        "summary": "List tasks, optionally filtered by profileId",
        "tags": ["tasks"],
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "profileId",
            "required": false,
            "description": "Filter by profile ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      },
      "post": {
        "summary": "Create a new automation task",
        "tags": ["tasks"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "profileId",
                  "name",
                  "scriptType",
                  "scriptContent"
                ],
                "properties": {
                  "profileId": {
                    "type": "string",
                    "description": "ID of the profile to run the task on"
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 200
                  },
                  "scriptType": {
                    "type": "string",
                    "enum": ["file", "inline"],
                    "description": "'file' = path to script file, 'inline' = script string"
                  },
                  "scriptContent": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Script file path or inline script"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
