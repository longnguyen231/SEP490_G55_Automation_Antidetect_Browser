        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["type", "host", "port"],
                "properties": {
                  "name": {
                    "type": "string",
                    "maxLength": 200,
                    "description": "Optional proxy label"
                  },
                  "type": {
                    "type": "string",
                    "enum": ["http", "https", "socks4", "socks5"]
                  },
                  "host": {
                    "type": "string",
                    "minLength": 1
                  },
                  "port": {
                    "type": "integer",
