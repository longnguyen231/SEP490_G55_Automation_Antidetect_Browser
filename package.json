{
  "name": "hlmckautomationantidetectbrowser",
  "version": "1.0.0",
  "description": "Browser profile management with antidetect capabilities using Electron and React",
  "main": "src/main/bootstrap.js",
  "scripts": {
    "dev": "concurrently -k -n \"VITE,ELECTRON\" -c \"cyan,magenta\" \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electronmon --watch src/main --watch src/preload --ignore dist --ignore release --ignore node_modules --ignore vendor --ignore data --ignore data/** --ignore logs --ignore src/data --ignore src/data/** --ignore src/data/logs --ignore src/data/logs/** --ignore **/*.json .",
    "prebuild": "node scripts/ensure-fsevents.js",
    "icons": "node scripts/make-icons.js",
    "build": "npm run icons && vite build && electron-builder",
    "build:vite": "vite build",
    "dist": "npm run build && npm run upload:release",
    "upload:release": "node scripts/upload-release.js",
    "start": "electron .",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "electronmon": {
    "watch": [
      "src/main",
      "src/preload"
    ],
    "ignore": [
      "dist",
      "release",
      "node_modules",
      "data",
      "data/**",
      "vendor",
      "logs",
      "src/data",
      "src/data/**",
      "src/data/logs",
      "src/data/logs/**"
    ]
  },
  "keywords": [
    "electron",
    "react",
    "browser",
    "antidetect",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.hlmck.antidetectbrowser",
    "productName": "HL-MCK Antidetect Browser",
    "asar": true,
    "asarUnpack": [
      "node_modules/playwright-core/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "build/1.png",
        "to": "icon.png"
      }
    ],
    "icon": "build/1.png",
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/preload/**/*",
      "package.json",
      "!node_modules/**/fsevents",
      "!node_modules/**/fsevents/**"
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HL-MCK Antidetect Browser"
    },
    "linux": {
      "target": "AppImage"
    },
    "afterPack": "./scripts/afterPack-obfuscate.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@electron/asar": "^3.2.10",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.17.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^2.3.0",
    "electronmon": "^2.0.4",
    "javascript-obfuscator": "^5.3.0",
    "jest": "^30.3.0",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9",
    "wait-on": "^9.0.1"
  },
  "dependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@monaco-editor/react": "^4.7.0",
    "@sentry/electron": "^7.10.0",
    "better-sqlite3": "^12.0.0",
    "bootstrap": "^5.3.8",
    "commander": "^12.1.0",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.0",
    "electron-store": "^8.2.0",
    "express": "^5.2.1",
    "fastify": "^5.8.2",
    "fingerprint-generator": "^2.1.55",
    "fingerprint-injector": "^2.1.55",
    "lucide-react": "^1.6.0",
    "monaco-editor": "^0.55.1",
    "node-cron": "^4.2.1",
    "pino": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "playwright": "npm:rebrowser-playwright@^1.52.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^18.3.1",
    "swagger-ui-express": "^5.0.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  }
}
